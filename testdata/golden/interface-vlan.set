set interfaces bridge br0 address dhcp
set interfaces bridge br0 description 'WAN'
set interfaces bridge br0 member interface eth0
set interfaces bridge br1 address 192.168.60.1/24
set interfaces bridge br1 description 'LAN'
set interfaces bridge br1 member interface eth1 allowed-vlan 20
set interfaces bridge br1 member interface eth1 native-vlan 1
set interfaces bridge br1 member interface eth2 allowed-vlan 10
set interfaces bridge br1 member interface eth2 native-vlan 1
set interfaces bridge br1 vif 10 address 192.168.10.1/24
set interfaces bridge br1 vif 10 description 'LAN.10'
set interfaces bridge br1 vif 20 address 192.168.20.1/24
set interfaces bridge br1 vif 20 description 'LAN.20'
set interfaces ethernet eth0 description 'WAN'
set interfaces ethernet eth1 description 'LAN'
set interfaces ethernet eth2 description 'LAN'
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 lease 21600
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 option default-router 192.168.60.1
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 option name-server 192.168.60.1
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 range 0 start 192.168.60.10
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 range 0 stop 192.168.60.137
set service dhcp-server shared-network-name LAN subnet 192.168.60.0/24 subnet-id 4052
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 lease 21600
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 option default-router 192.168.10.1
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 option name-server 192.168.10.1
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 range 0 start 192.168.10.10
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 range 0 stop 192.168.10.137
set service dhcp-server shared-network-name LAN.10 subnet 192.168.10.0/24 subnet-id 10
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 lease 21600
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 option default-router 192.168.20.1
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 option name-server 192.168.20.1
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 range 0 start 192.168.20.10
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 range 0 stop 192.168.20.137
set service dhcp-server shared-network-name LAN.20 subnet 192.168.20.0/24 subnet-id 20
set service dns forwarding allow-from 192.168.60.0/24
set service dns forwarding allow-from 192.168.10.0/24
set service dns forwarding allow-from 192.168.20.0/24
set service dns forwarding cache-size 0
set service dns forwarding listen-address 192.168.60.1
set service dns forwarding listen-address 192.168.10.1
set service dns forwarding listen-address 192.168.20.1
set service ssh port 22
